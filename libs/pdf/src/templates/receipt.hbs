<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Phiếu thu {{transaction.id}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Times New Roman', serif; font-size: 13px; color: #111; line-height: 1.7; }
    .header { text-align: center; border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 18px; }
    .header h1 { font-size: 20px; font-weight: bold; text-transform: uppercase; }
    .store-info { text-align: center; font-size: 12px; color: #444; margin-bottom: 6px; }
    .receipt-no { font-size: 13px; text-align: right; margin-bottom: 10px; color: #555; }
    table.info { width: 100%; border-collapse: collapse; }
    table.info td { padding: 5px 8px; vertical-align: top; }
    table.info td:first-child { width: 40%; font-weight: 600; }
    .highlight { font-weight: bold; font-size: 14px; }
    .amount-words { font-style: italic; color: #333; }
    .box { border: 2px solid #333; padding: 12px 16px; margin: 16px 0; text-align: center; }
    .box .amount { font-size: 22px; font-weight: bold; letter-spacing: 1px; }
    .box .amount-w { font-size: 13px; font-style: italic; margin-top: 4px; }
    .signatures { display: flex; justify-content: space-between; margin-top: 36px; }
    .sig-block { text-align: center; width: 45%; }
    .sig-block .sig-title { font-weight: bold; margin-bottom: 55px; }
    .sig-block .sig-name { border-top: 1px solid #555; padding-top: 4px; font-size: 12px; }
    .footer { margin-top: 16px; font-size: 11px; color: #666; text-align: center; border-top: 1px solid #ccc; padding-top: 8px; }
    .remaining { background: #f5f5f5; border: 1px solid #ddd; padding: 8px 12px; margin-top: 12px; font-size: 12px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="store-info">{{store.name}} — {{store.address}} — ĐT: {{store.phone}}</div>
    <h1>Phiếu thu</h1>
  </div>

  <div class="receipt-no">Số phiếu: {{transaction.id}}</div>

  <table class="info">
    <tr><td>Ngày thu:</td><td class="highlight">{{vndDate transaction.transaction_date}} {{timeStr transaction.transaction_date}}</td></tr>
    <tr><td>Khách hàng:</td><td class="highlight">{{customer.full_name}}</td></tr>
    <tr><td>CCCD/CMND:</td><td>{{customer.identity_number}}</td></tr>
    <tr><td>Số điện thoại:</td><td>{{customer.phone}}</td></tr>
    <tr><td>Mã hợp đồng:</td><td class="highlight">{{contract.contract_code}}</td></tr>
    <tr><td>Loại giao dịch:</td><td>{{txnTypeLabel transaction.transaction_type}}</td></tr>
    <tr><td>Phương thức TT:</td><td>{{paymentMethodLabel transaction.payment_method}}</td></tr>
    {{#if transaction.note}}<tr><td>Ghi chú:</td><td>{{transaction.note}}</td></tr>{{/if}}
  </table>

  <div class="box">
    <div>Số tiền thu</div>
    <div class="amount">{{vnd transaction.amount}}</div>
    <div class="amount-w">({{vndWords transaction.amount}})</div>
  </div>

  {{#if remaining}}
  <div class="remaining">
    Số dư còn lại (ước tính): <strong>{{vnd remaining}}</strong>
  </div>
  {{/if}}

  <div class="signatures">
    <div class="sig-block">
      <div class="sig-title">KHÁCH HÀNG<br>(Ký và ghi rõ họ tên)</div>
      <div class="sig-name">{{customer.full_name}}</div>
    </div>
    <div class="sig-block">
      <div class="sig-title">THU NGÂN / NHÂN VIÊN<br>(Ký và ghi rõ họ tên)</div>
      <div class="sig-name">&nbsp;</div>
    </div>
  </div>

  <div class="footer">In ngày: {{printDate}} — Hệ thống quản lý cầm đồ Paw8</div>
</body>
</html>
